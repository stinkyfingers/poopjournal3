[
  {
    "name": "poopjournal-api",
    "image": "671958020402.dkr.ecr.us-west-1.amazonaws.com/poopjournal:latest",
    "portMappings": [
      { "containerPort": 8080, "protocol": "tcp" }
    ],
    "environment": [
      { "name": "S3_BUCKET", "value": "poopjournal-data-prod" }
    ],
    "essential": true,
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "/ecs/poopjournal-api",
        "awslogs-region": "us-west-1",
        "awslogs-stream-prefix": "ecs"
      }
    }
  }
]
